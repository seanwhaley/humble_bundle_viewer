# HB Library Viewer Secrets
# ⚠️  KEEP THIS PRIVATE - DO NOT COMMIT TO GIT
# Copy to backend/.env and replace placeholder values.

# Required: Humble Bundle session cookie (_simpleauth_sess)
HUMBLE_AUTH_COOKIE="your_simpleauth_sess_cookie_value_here"

# Optional overrides (non-secret settings live in backend/config.yaml)
# HUMBLE_DOWNLOAD__BASE_FOLDER="./Humble_Library_Downloads"
# HUMBLE_DOWNLOAD__PROMPT_BEFORE_DOWNLOAD="true"
# HUMBLE_DOWNLOAD__FORCE_INDIVIDUAL_FILE_DOWNLOADS="null"
# HUMBLE_LOGGING__LEVEL="debug"
# HUMBLE_PROXY__PASSWORD="proxy_password"
# HUMBLE_CONFIG_YAML="backend/config.yaml"
