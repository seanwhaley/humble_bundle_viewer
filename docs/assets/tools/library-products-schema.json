    "Product": {
      "additionalProperties": true,
      "description": "One product in the Humble Bundle library.\n\nRepresents a single purchase or bundle with all its downloadable\nfiles across different platforms and formats.\n\nAttributes\n----------\ngamekey : str\n    Unique product identifier\nproduct_name : str\n    Human-readable product name\nmachine_name : str\n    Slug/identifier for the product\ncategory : str\n    Product category (ebook, audiobook, video, etc.)\ncreated_at : str\n    ISO 8601 timestamp of purchase\nsubproducts : list[Subproduct]\n    Normalized subproducts for bundles\ndownloads : list[Download]\n    List of downloadable files\nkeys : list[KeyEntry]\n    List of redeemable keys (when present)\namount_spent : float\n    Amount spent on this product\n\nExamples\n--------\n>>> product = Product(\n...     gamekey='abc123',\n...     product_name='My Book',\n...     machine_name='my_book',\n...     category='ebook',\n...     downloads=[],\n...     amount_spent=9.99\n... )\n>>> product.gamekey\n'abc123'\n\n>>> len(product.downloads)\n0",
      "properties": {
        "gamekey": {
          "description": "Unique product key",
          "title": "Gamekey",
          "type": "string"
        },
        "product_name": {
          "description": "Human-readable name",
          "title": "Product Name",
          "type": "string"
        },
        "machine_name": {
          "description": "Slug/identifier",
          "title": "Machine Name",
          "type": "string"
        },
        "category": {
          "description": "Product category",
          "title": "Category",
          "type": "string"
        },
        "created_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "ISO 8601 timestamp of purchase",
          "title": "Created At"
        },
        "subproducts": {
          "description": "Normalized subproducts",
          "items": {
            "$ref": "#/$defs/Subproduct"
          },
          "title": "Subproducts",
          "type": "array"
        },
        "downloads": {
          "description": "List of downloadable files",
          "items": {
            "$ref": "#/$defs/Download"
          },
          "title": "Downloads",
          "type": "array"
        },
        "keys": {
          "description": "List of redeemable keys",
          "items": {
            "$ref": "#/$defs/KeyEntry"
          },
          "title": "Keys",
          "type": "array"
        },
        "amount_spent": {
          "default": 0.0,
          "description": "Amount spent",
          "minimum": 0.0,
          "title": "Amount Spent",
          "type": "number"
        }
      },
      "required": [
        "gamekey",
        "product_name",
        "machine_name",
        "category"
      ],
      "title": "Product",
      "type": "object"
    },
