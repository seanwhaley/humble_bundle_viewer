{
  "$defs": {
    "Download": {
      "additionalProperties": true,
      "description": "Single download file (one platform and format).\n\nRepresents one downloadable file in one specific format (e.g., PDF,\nEPUB, M4B). A product may have multiple downloads for different\nplatforms or formats.\n\nAttributes\n----------\nplatform : str\n    Platform type (e.g., 'ebook', 'audio', 'video')\nname : str\n    Human-readable file name\nurl : str\n    Full download URL (HTTP or HTTPS)\nsize_bytes : int\n    File size in bytes\nchecksums : dict\n    File integrity hashes (keys: 'md5', 'sha1', etc.)\n\nExamples\n--------\n>>> download = Download(\n...     platform='ebook',\n...     name='My_Book.pdf',\n...     url='https://example.com/file.pdf',\n...     size_bytes=1024000,\n...     checksums={'md5': 'abc123', 'sha1': 'def456'}\n... )\n>>> download.platform\n'ebook'\n\n>>> download.model_dump_json()  # doctest: +SKIP\n'{...}'",
      "properties": {
        "platform": {
          "description": "Platform type (e.g., 'ebook', 'audio')",
          "title": "Platform",
          "type": "string"
        },
        "name": {
          "description": "File name",
          "title": "Name",
          "type": "string"
        },
        "url": {
          "description": "Full download URL",
          "title": "Url",
          "type": "string"
        },
        "size_bytes": {
          "default": 0,
          "description": "File size in bytes",
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "checksums": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Hash checksums (md5, sha1, etc.)",
          "title": "Checksums",
          "type": "object"
        },
        "file_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "File extension inferred from name or URL (e.g., pdf, epub)",
          "title": "File Type"
        },
        "display_category": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Viewer-facing download family (ebook, audiobook, video, software, generic)",
          "title": "Display Category"
        },
        "content_label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Primary user-facing content label such as EPUB, MP3, or Linux 64-bit",
          "title": "Content Label"
        },
        "package_label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Normalized package or delivery label such as ZIP, DEB, DMG, or Installer",
          "title": "Package Label"
        },
        "display_label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Unique viewer-facing label to show in route actions and filters",
          "title": "Display Label"
        },
        "display_detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional secondary detail for the viewer display label",
          "title": "Display Detail"
        }
      },
      "required": [
        "platform",
        "name",
        "url"
      ],
      "title": "Download",
      "type": "object"
    },
