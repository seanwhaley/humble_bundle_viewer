  "additionalProperties": true,
  "description": "Complete Humble Bundle library data.\n\nAggregates all products in the user's library along with metadata\nabout when the data was captured.\n\nAttributes\n----------\nproducts : list[Product]\n    All products in the library\ntotal_products : int\n    Number of products\ncaptured_at : str\n    ISO 8601 timestamp of capture\n\nExamples\n--------\n>>> lib_data = LibraryData(\n...     products=[],\n...     total_products=0,\n...     captured_at='2026-01-30T12:00:00'\n... )\n>>> lib_data.total_products\n0\n\n>>> lib_data.model_dump_json()  # doctest: +SKIP\n'{...}'\n\n>>> json_str = lib_data.model_dump_json(indent=2)  # doctest: +SKIP",
  "properties": {
    "products": {
      "description": "All products",
      "items": {
        "$ref": "#/$defs/Product"
      },
      "title": "Products",
      "type": "array"
    },
    "total_products": {
      "default": 0,
      "description": "Total product count",
      "minimum": 0,
      "title": "Total Products",
      "type": "integer"
    },
    "captured_at": {
      "description": "ISO 8601 timestamp when data was captured",
      "title": "Captured At",
      "type": "string"
    }
  },
  "required": [
    "captured_at"
  ],
  "title": "LibraryData",
  "type": "object"
